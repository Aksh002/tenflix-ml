# TenFlix V4 promoted model
TENFLIX_V4_RUN=artifacts/movielens-v4-tuned-eval-v4-production

# FastAPI product service
TENFLIX_API_HOST=127.0.0.1
TENFLIX_API_PORT=8000
TENFLIX_DEFAULT_PROVIDER_REGION=IN
TENFLIX_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
TENFLIX_DEV_AUTH_USER_ID=
TENFLIX_DEV_AUTH_EMAIL=dev@tenflix.local

# Supabase / Postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# TMDb enrichment
TMDB_API_TOKEN=
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# Next.js frontend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_TENFLIX_API_URL=http://127.0.0.1:8000
